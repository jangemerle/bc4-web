{
  "name": "kvalt",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "playground": "vite --open /playground/",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "security": "bash scripts/security-scan.sh",
    "optimize-images": "node scripts/optimize-images.mjs",
    "audit:tokens": "node scripts/audit-tokens.mjs",
    "precommit": "npm run security",
    "prepare": "[ -d .git ] && (npx --yes husky || true)",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:visual": "playwright test tests/e2e/visual/",
    "test:visual:update": "playwright test tests/e2e/visual/ --update-snapshots",
    "test:a11y": "playwright test tests/e2e/a11y/ --project=chromium",
    "test:screenshots": "playwright test tests/e2e/capture-screenshots.spec.ts",
    "setup-hooks": "node scripts/setup-git-hooks.mjs",
    "log": "git log --oneline --graph --decorate --all",
    "log:file": "git log --follow -p --",
    "log:today": "git log --oneline --since=midnight",
    "log:search": "git log --oneline --all --grep",
    "size": "size-limit",
    "size:check": "size-limit --json"
  },
  "size-limit": [
    {
      "name": "Main bundle (gzip)",
      "path": "dist/assets/main-*.js",
      "gzip": true,
      "limit": "600 kB"
    },
    {
      "name": "App code (gzip)",
      "path": "dist/assets/src-*.js",
      "gzip": true,
      "limit": "70 kB"
    }
  ],
  "dependencies": {
    "@fontsource/dm-sans": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@fontsource/lora": "^5.2.8",
    "@fontsource/manrope": "^5.2.8",
    "@fontsource/playfair-display": "^5.2.8",
    "@fontsource/sora": "^5.2.8",
    "@fontsource/space-grotesk": "^5.2.10",
    "@fontsource/space-mono": "^5.2.9",
    "@hookform/resolvers": "^5.2.2",
    "clsx": "^2.1.1",
    "culori": "^4.0.2",
    "extract-colors": "^4.2.1",
    "hsluv": "^1.0.1",
    "i18next": "^26.0.4",
    "i18next-browser-languagedetector": "^8.2.1",
    "lucide-react": "^0.577.0",
    "motion": "^12.36.0",
    "react": "^19.2.4",
    "react-colorful": "^5.6.1",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.72.1",
    "react-i18next": "^17.0.3",
    "react-mosaic-component": "^7.0.0-beta0",
    "react-router-dom": "^7.14.1",
    "tailwind-merge": "^3.5.0",
    "typopo": "^3.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@changesets/cli": "^2.30.0",
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.58.2",
    "@size-limit/file": "^12.0.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vercel/node": "^5.7.2",
    "@vitejs/plugin-react": "^6.0.0",
    "@vitest/coverage-v8": "^4.1.3",
    "autoprefixer": "^10.4.27",
    "eslint": "^9.39.4",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-security": "^4.0.0",
    "globals": "^17.4.0",
    "jsdom": "^29.0.2",
    "postcss": "^8.5.8",
    "sharp": "^0.34.5",
    "size-limit": "^12.0.1",
    "tailwindcss": "^3.4.19",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^8.0.7",
    "vitest": "^4.1.3"
  }
}
