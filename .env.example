# BC4Cloud — environment variables example
#
# Zkopíruj jako .env (root projektu) a vyplň reálné hodnoty.
# .env je v .gitignore — nikdy ho necommituj.

# Apify token pro scraping bc4.cz a další stránky
# Get token: https://console.apify.com/account/integrations
APIFY_TOKEN=apify_api_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Vercel Functions environment (set v Vercel UI, ne tady)
# NOTIFICATION_EMAIL=obchod@bc4cloud.cz
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
